# Postgres connection (Neon or any Postgres with pgvector).
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Vertex AI (required for embeddings).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Optional; defaults to us-central1.
GOOGLE_CLOUD_LOCATION=us-central1

# Auth (recommended for production): service account JSON key path.
# Create in GCP: IAM & Admin → Service Accounts → Create → Keys → Add JSON key.
# Grant the service account role "Vertex AI User" (or minimal role with Vertex AI access).
GOOGLE_APPLICATION_CREDENTIALS=E:\project-9f422e34-396d-40bc-9bb-8ed4b97e739b.json
